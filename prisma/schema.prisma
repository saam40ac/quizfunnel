// Schema database QuizFunnel
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  OWNER
  MEMBER
}

enum Plan {
  FREE
  PRO
  BUSINESS
}

enum QuizStatus {
  DRAFT
  PUBLISHED
}

enum QuestionType {
  SINGLE
  MULTIPLE
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  role         Role      @default(OWNER)
  workspaceId  String?
  workspace    Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())
}

model Workspace {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  plan            Plan     @default(FREE)
  systemeApiKey   String?
  customDomain    String?  @unique
  createdAt       DateTime @default(now())
  users           User[]
  quizzes         Quiz[]
}

model Quiz {
  id              String     @id @default(cuid())
  workspaceId     String
  workspace       Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title           String
  slug            String
  description     String?
  status          QuizStatus @default(DRAFT)

  // ---- Brief usato per la generazione AI ----
  briefSummary    String?
  briefTarget     String?
  briefProblem    String?
  briefTone       String?    @default("professionale")
  briefGoal       String?

  // ---- Branding ----
  primaryColor    String     @default("#0f172a")
  accentColor     String     @default("#f59e0b")
  coverImageUrl   String?

  // ---- CTA finale ----
  ctaText         String     @default("Scopri di più")
  ctaUrl          String?

  // ---- Lead capture ----
  leadCaptureMode String     @default("END")
  privacyText     String?

  // ---- Result mapping ----
  resultMappings  Json?

  // ---- Systeme.io ----
  systemeTagName  String?

  // ---- Metadata ----
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  questions       Question[]
  leads           Lead[]
  emailVersions   EmailSequenceVersion[]
  emails          QuizEmail[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
}

model EmailSequenceVersion {
  id           String      @id @default(cuid())
  quizId       String
  quiz         Quiz        @relation(fields: [quizId], references: [id], onDelete: Cascade)
  // Numero progressivo della versione (1, 2, 3, …)
  versionNumber Int
  // Etichetta libera che il marketer può dare alla versione (es. "v1 — empatica")
  label        String?
  // Note libere (es. "v2 ha avuto +12% di click")
  notes        String?     @db.Text
  // Una sola versione per quiz può essere "attiva"
  isActive     Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  emails       QuizEmail[]

  @@unique([quizId, versionNumber])
  @@index([quizId])
}

model QuizEmail {
  id             String                @id @default(cuid())
  // Le email appartengono a una versione specifica della sequenza
  versionId      String
  version        EmailSequenceVersion  @relation(fields: [versionId], references: [id], onDelete: Cascade)
  // Manteniamo un riferimento al quiz per query veloci
  quizId         String
  quiz           Quiz                  @relation(fields: [quizId], references: [id], onDelete: Cascade)
  order          Int      // 1, 2, 3
  internalLabel  String
  suggestedDelay String?  @default("Subito")
  subject        String
  preheader      String?
  body           String   @db.Text
  ctaText        String   @default("Scopri di più")
  ctaUrl         String?
  internalNotes  String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([versionId, order])
  @@index([versionId])
  @@index([quizId])
}

model Question {
  id        String       @id @default(cuid())
  quizId    String
  quiz      Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  order     Int
  text      String
  type      QuestionType @default(SINGLE)
  required  Boolean      @default(true)
  answers   Answer[]

  @@index([quizId])
}

model Answer {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  order      Int
  text       String
  score      Int      @default(0)

  @@index([questionId])
}

model Lead {
  id              String   @id @default(cuid())
  quizId          String
  quiz            Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  name            String
  email           String
  phone           String?
  score           Int      @default(0)
  resultLabel     String?
  answersJson     Json
  syncedToSysteme Boolean  @default(false)
  systemeContactId String?
  createdAt       DateTime @default(now())

  @@index([quizId])
  @@index([email])
}
