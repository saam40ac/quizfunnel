// Schema database QuizFunnel
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  OWNER
  MEMBER
}

enum Plan {
  FREE
  PRO
  BUSINESS
}

enum QuizStatus {
  DRAFT
  PUBLISHED
}

enum QuestionType {
  SINGLE
  MULTIPLE
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  // passwordHash è OPZIONALE: gli utenti creati via auto-signup post-pagamento
  // non hanno password iniziale; entrano via magic link e possono impostare la
  // password successivamente dalle settings.
  passwordHash String?
  role         Role      @default(OWNER)
  workspaceId  String?
  workspace    Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())
  magicLinks   MagicLink[]
}

model Workspace {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  plan            Plan     @default(FREE)
  systemeApiKey   String?
  customDomain    String?  @unique
  // Logo del workspace - base64 data URL (data:image/png;base64,...)
  logoUrl         String?  @db.Text
  logoUrlDark     String?  @db.Text  // versione per sfondi scuri (opzionale)
  // Email usata su Systeme.io per il pagamento (può essere diversa dall'email login)
  billingEmail    String?
  createdAt       DateTime @default(now())
  users           User[]
  quizzes         Quiz[]
  subscriptions   Subscription[]
  webhookEvents   WebhookEvent[]
}

/// Stato dell'abbonamento di un workspace.
/// Aggiornato dai webhook in arrivo da Systeme.io.
model Subscription {
  id            String    @id @default(cuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  // Piano a cui l'utente si è abbonato
  plan          Plan
  // Email Systeme.io con cui ha pagato
  billingEmail  String
  // Stato corrente
  status        String    @default("active") // "active", "cancelled", "expired"
  // Tag su Systeme.io che attiva questo abbonamento
  systemeTag    String?
  // Quando inizia/finisce
  startedAt     DateTime  @default(now())
  cancelledAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([workspaceId])
  @@index([billingEmail])
  @@index([status])
}

/// Log degli eventi ricevuti dai webhook Systeme.io.
/// Usato per debug e per evitare di processare lo stesso evento due volte.
model WebhookEvent {
  id            String    @id @default(cuid())
  // Provider che ha mandato l'evento (per ora sempre "systeme")
  provider      String    @default("systeme")
  // Tipo evento (es. "tag_added", "tag_removed", "subscription_cancelled")
  eventType     String
  // Email del contatto coinvolto
  email         String
  // Tag (per eventi tag_added/removed)
  tagName       String?
  // Workspace su cui è stato applicato (NULL se non trovato)
  workspaceId   String?
  workspace     Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  // Esito del processing
  status        String    @default("processed") // "processed", "ignored", "error"
  errorMessage  String?   @db.Text
  // Payload originale per debug
  rawPayload    Json?
  createdAt     DateTime  @default(now())

  @@index([email])
  @@index([createdAt])
  @@index([workspaceId])
}

/// Magic link per il login senza password.
/// Creato dal webhook quando un utente paga su Systeme.io (auto-signup).
/// L'utente clicca il link nell'email Systeme.io e entra direttamente in dashboard.
/// Single-use: dopo il primo utilizzo viene marcato come "usato".
model MagicLink {
  id          String    @id @default(cuid())
  token       String    @unique
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Quando scade (default: 30 giorni)
  expiresAt   DateTime
  // Se è già stato usato (single-use)
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

model Quiz {
  id              String     @id @default(cuid())
  workspaceId     String
  workspace       Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title           String
  slug            String
  description     String?
  status          QuizStatus @default(DRAFT)

  // ---- Brief usato per la generazione AI ----
  briefSummary    String?
  briefTarget     String?
  briefProblem    String?
  briefTone       String?    @default("professionale")
  briefGoal       String?

  // ---- Branding ----
  primaryColor    String     @default("#0f172a")
  accentColor     String     @default("#f59e0b")
  coverImageUrl   String?
  // Override logo solo per questo quiz (se vuoto usa quello del workspace)
  logoUrl         String?    @db.Text
  // Posizionamento logo: "center" | "left" | "hidden"
  logoPosition    String     @default("center")

  // ---- CTA finale ----
  ctaText         String     @default("Scopri di più")
  ctaUrl          String?

  // ---- Lead capture ----
  leadCaptureMode String     @default("END")
  privacyText     String?

  // ---- Result mapping ----
  resultMappings  Json?

  // ---- Systeme.io ----
  systemeTagName  String?

  // ---- Metadata ----
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  questions       Question[]
  leads           Lead[]
  emailVersions   EmailSequenceVersion[]
  emails          QuizEmail[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
}

model EmailSequenceVersion {
  id           String      @id @default(cuid())
  quizId       String
  quiz         Quiz        @relation(fields: [quizId], references: [id], onDelete: Cascade)
  // Numero progressivo della versione (1, 2, 3, …)
  versionNumber Int
  // Etichetta libera che il marketer può dare alla versione (es. "v1 — empatica")
  label        String?
  // Note libere (es. "v2 ha avuto +12% di click")
  notes        String?     @db.Text
  // Una sola versione per quiz può essere "attiva"
  isActive     Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  emails       QuizEmail[]

  @@unique([quizId, versionNumber])
  @@index([quizId])
}

model QuizEmail {
  id             String                @id @default(cuid())
  // Le email appartengono a una versione specifica della sequenza
  versionId      String
  version        EmailSequenceVersion  @relation(fields: [versionId], references: [id], onDelete: Cascade)
  // Manteniamo un riferimento al quiz per query veloci
  quizId         String
  quiz           Quiz                  @relation(fields: [quizId], references: [id], onDelete: Cascade)
  order          Int      // 1, 2, 3
  internalLabel  String
  suggestedDelay String?  @default("Subito")
  subject        String
  preheader      String?
  body           String   @db.Text
  ctaText        String   @default("Scopri di più")
  ctaUrl         String?
  internalNotes  String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([versionId, order])
  @@index([versionId])
  @@index([quizId])
}

model Question {
  id        String       @id @default(cuid())
  quizId    String
  quiz      Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  order     Int
  text      String
  type      QuestionType @default(SINGLE)
  required  Boolean      @default(true)
  answers   Answer[]

  @@index([quizId])
}

model Answer {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  order      Int
  text       String
  score      Int      @default(0)

  @@index([questionId])
}

model Lead {
  id              String   @id @default(cuid())
  quizId          String
  quiz            Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  name            String
  email           String
  phone           String?
  score           Int      @default(0)
  resultLabel     String?
  answersJson     Json
  syncedToSysteme Boolean  @default(false)
  systemeContactId String?
  createdAt       DateTime @default(now())

  @@index([quizId])
  @@index([email])
}

/// Log delle chiamate AI per monitoraggio costi.
/// Ogni chiamata a Anthropic viene registrata qui: workspace, tipo operazione,
/// token in/out, costo stimato in euro (basato sui prezzi del modello al momento).
model AIUsageLog {
  id              String   @id @default(cuid())
  workspaceId     String?
  // Tipo di operazione: "quiz_generation", "email_generation", ecc.
  operation       String
  model           String
  inputTokens     Int      @default(0)
  outputTokens   Int      @default(0)
  // Costo stimato in euro (calcolato lato server al momento della chiamata)
  estimatedCostEur Float   @default(0)
  // Eventuale errore in caso di fallimento
  errorMessage    String?
  createdAt       DateTime @default(now())

  @@index([workspaceId])
  @@index([createdAt])
  @@index([operation])
}
