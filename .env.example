# =============================================================
# QuizFunnel — Variabili d'ambiente
# =============================================================
# Copia questo file in `.env` (in locale) o impostali su Vercel
# (Project → Settings → Environment Variables).
# =============================================================

# --- Database PostgreSQL (Render / Neon / Supabase) ---
# Render: Render → New → PostgreSQL → copia "External Database URL"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# --- Auth.js / NextAuth v5 ---
# Genera con: openssl rand -base64 32
AUTH_SECRET="change-me-with-a-random-32-byte-base64-string"
# In produzione Vercel imposta automaticamente AUTH_URL al tuo dominio.
# In locale lascia commentato.
# AUTH_URL="http://localhost:3000"

# --- App URL (per costruire link assoluti embed/share) ---
NEXT_PUBLIC_APP_URL="https://tuodominio.it"

# --- Seed iniziale (solo prima esecuzione di `npm run db:seed`) ---
SEED_ADMIN_EMAIL="admin@tuodominio.it"
SEED_ADMIN_PASSWORD="ChangeMeSubito!2026"
